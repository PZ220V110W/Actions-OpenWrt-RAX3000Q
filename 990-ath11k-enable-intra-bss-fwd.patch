--- a/drivers/net/wireless/ath/ath11k/mac.c
+++ b/drivers/net/wireless/ath/ath11k/mac.c
@@ -5154,6 +5154,33 @@
 			   arg.channel.freq, arg.vdev_id);
 	}
 
+	/* Enable intra-BSS forwarding at firmware level.
+	 *
+	 * WMI_VDEV_PARAM_INTRA_BSS_FWD controls whether the wireless
+	 * firmware forwards data frames between stations associated to
+	 * the same BSS without sending them to the host.
+	 *
+	 * The firmware default is OFF (blocked) on QCN6122/IPQ5018,
+	 * which prevents clients on the same SSID from communicating
+	 * even when the kernel bridge hairpin mode is enabled, because
+	 * the firmware drops the packets before they reach the host.
+	 *
+	 * When ap_isolate is NOT set (default, allow client-to-client),
+	 * we must enable intra-BSS forwarding in the firmware.
+	 * When ap_isolate IS set, we disable it to enforce isolation.
+	 */
+	if (arvif->vdev_type == WMI_VDEV_TYPE_AP) {
+		u32 fwd_enable = !arvif->vif->bss_conf.nss_ap_isolate;
+
+		ret = ath11k_wmi_vdev_set_param_cmd(ar, arvif->vdev_id,
+						    WMI_VDEV_PARAM_INTRA_BSS_FWD,
+						    fwd_enable);
+		if (ret)
+			ath11k_warn(ar->ab, "failed to set intra-bss fwd on vdev %d: %d
+",
+				    arvif->vdev_id, ret);
+	}
+
 	ret = ath11k_mac_set_txbf_conf(arvif);
 	if (ret)
 		ath11k_warn(ab, "failed to set txbf conf for vdev %d: %d\n",
